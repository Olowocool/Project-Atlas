# ============================================
# Application Settings
# ============================================
ENVIRONMENT=development
DEBUG=false
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
LOG_LEVEL=INFO

# ============================================
# Database (PostgreSQL + PostGIS)
# ============================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=atlas
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Connection strings (constructed from above)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/atlas
DATABASE_URL_SYNC=postgresql://postgres:postgres@postgres:5432/atlas

# Pool settings
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_ECHO=false

# ============================================
# Redis
# ============================================
REDIS_URL=redis://redis:6379/0
REDIS_KEY_PREFIX=atlas:

# ============================================
# Celery (Task Queue)
# ============================================
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ============================================
# CORS (Cross-Origin Resource Sharing)
# ============================================
CORS_ORIGINS=["http://localhost:3000"]

# ============================================
# Frontend (Next.js)
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:8000

# ============================================
# External API Keys (Optional)
# ============================================
MAPBOX_API_KEY=
GOOGLE_GEOCODING_API_KEY=
OPENAI_API_KEY=

# ============================================
# Email (Optional - for notifications)
# ============================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@projectatlas.dev

# ============================================
# File Storage (Optional - for imports)
# ============================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1